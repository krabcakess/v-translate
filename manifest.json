{
    "manifest_version": 3,
    "name": "V-Translate",
    "version": "1.0.0",
    "description": "An almost real-time english subtitles generator for japanese livestreams",
    "permissions": ["activeTab"],
    "host_permissions": ["https://*.youtube.com/*"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.youtube.com/*"],
            "js": ["contentScripts.js"]
        }
    ]

}