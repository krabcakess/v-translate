{
    "manifest_version": 3,
    "name": "V-Translate",
    "version": "1.0.0",
    "description": "An *almost* real-time english subtitles generator for japanese livestreams",
    "permissions": ["activeTab", "tabs", "storage"],
    "host_permissions": ["https://*.youtube.com/*"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://*.youtube.com/*"],
            "js": ["contentScript.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["assets/t-logo.png"],
            "matches": ["https://*.youtube.com/*"]
        }
    ]

}